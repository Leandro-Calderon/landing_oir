---
interface Props {
  icon: string;
  title: string;
  description: string;
  email: string;
  iconBgClass?: string;
}

const { icon, title, description, email, iconBgClass = "bg-primary-light" } = Astro.props;
---

<div class="bg-surface-card p-8 rounded-2xl shadow-sm border border-outline/30 flex flex-col items-center text-center reveal">
  <!-- Icon -->
  <div class={`w-14 h-14 ${iconBgClass} rounded-full flex items-center justify-center mb-5`}>
    <span class="material-symbols-outlined text-primary text-2xl" aria-hidden="true">{icon}</span>
  </div>

  <!-- Title -->
  <h3 class="text-2xl font-bold mb-3 text-on-background">{title}</h3>

  <!-- Description -->
  <p class="text-on-surface text-sm mb-6">{description}</p>

  <!-- Email + Copy -->
  <div class="flex items-center gap-2 bg-surface-alt p-3 rounded-lg w-full">
    <a
      href={`mailto:${email}`}
      class="text-sm font-semibold text-primary truncate flex-1 text-left hover:underline"
      aria-label={`Enviar correo a ${email}`}
    >
      {email}
    </a>
    <button
      class="copy-btn p-2 hover:bg-primary hover:text-on-primary rounded-md transition-colors shrink-0"
      data-email={email}
      title="Copiar al portapapeles"
      aria-label={`Copiar ${email} al portapapeles`}
    >
      <span class="material-symbols-outlined text-base" aria-hidden="true">content_copy</span>
    </button>
  </div>
</div>
