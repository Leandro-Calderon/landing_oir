---
const navLinks = [
  { href: "#nosotros", label: "Nosotros" },
  { href: "#servicios", label: "Servicios" },
  { href: "#clientes", label: "Clientes" },
  { href: "#contacto", label: "Contacto" },
];
---

<!-- Navbar -->
<header
  id="navbar"
  class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-md shadow-sm transition-shadow duration-300"
>
  <nav class="flex justify-between items-center w-full px-4 h-16 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2 text-primary shrink-0" aria-label="Inicio">
      <span class="material-symbols-outlined text-primary" aria-hidden="true">security</span>
      <span class="text-lg font-bold tracking-tight">O.I.R. Seguridad</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          class="text-on-surface hover:text-primary transition-colors font-medium text-sm"
          href={link.href}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Desktop CTA -->
    <a
      class="hidden md:flex items-center gap-2 px-4 py-2 bg-primary text-on-primary rounded-lg font-semibold hover:bg-primary-dark transition-all text-sm"
      href="mailto:presupuesto@oirseguridad.com"
    >
      <span>Contacto</span>
    </a>

    <!-- Mobile Menu Toggle -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-primary shrink-0"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span class="material-symbols-outlined" id="menu-icon-open" aria-hidden="true">menu</span>
      <span class="material-symbols-outlined hidden" id="menu-icon-close" aria-hidden="true">close</span>
    </button>
  </nav>
</header>

<!-- Mobile Drawer Overlay -->
<div
  id="mobile-overlay"
  class="fixed inset-0 bg-black/50 z-[55] opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  aria-hidden="true"
></div>

<!-- Mobile Drawer -->
<aside
  id="mobile-drawer"
  class="fixed top-0 right-0 h-full w-72 bg-surface-card z-[60] shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out md:hidden"
  role="dialog"
  aria-label="Menú de navegación"
  aria-modal="true"
>
  <div class="flex flex-col h-full">
    <!-- Drawer Header -->
    <div class="flex items-center justify-between px-4 h-16 border-b border-outline">
      <span class="text-lg font-bold text-primary">Menú</span>
      <button
        id="drawer-close"
        class="p-2 text-on-surface hover:text-primary transition-colors"
        aria-label="Cerrar menú"
      >
        <span class="material-symbols-outlined" aria-hidden="true">close</span>
      </button>
    </div>

    <!-- Drawer Links -->
    <nav class="flex flex-col py-4" aria-label="Navegación móvil">
      {navLinks.map((link) => (
        <a
          class="mobile-nav-link px-6 py-4 text-on-background hover:bg-surface-alt hover:text-primary transition-colors font-medium text-base border-b border-outline/30"
          href={link.href}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Drawer CTA -->
    <div class="mt-auto p-4 border-t border-outline">
      <a
        class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-primary text-on-primary rounded-lg font-semibold hover:bg-primary-dark transition-all text-sm"
        href="mailto:presupuesto@oirseguridad.com"
      >
        <span class="material-symbols-outlined text-base" aria-hidden="true">mail</span>
        <span>Contacto</span>
      </a>
    </div>
  </div>
</aside>

<script>
  // Mobile drawer logic
  const toggle = document.getElementById("menu-toggle");
  const drawer = document.getElementById("mobile-drawer");
  const overlay = document.getElementById("mobile-overlay");
  const drawerClose = document.getElementById("drawer-close");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");

  function openDrawer() {
    drawer?.classList.remove("translate-x-full");
    overlay?.classList.remove("opacity-0", "pointer-events-none");
    overlay?.classList.add("opacity-100", "pointer-events-auto");
    iconOpen?.classList.add("hidden");
    iconClose?.classList.remove("hidden");
    toggle?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeDrawer() {
    drawer?.classList.add("translate-x-full");
    overlay?.classList.add("opacity-0", "pointer-events-none");
    overlay?.classList.remove("opacity-100", "pointer-events-auto");
    iconOpen?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
    toggle?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", openDrawer);
  drawerClose?.addEventListener("click", closeDrawer);
  overlay?.addEventListener("click", closeDrawer);
  mobileLinks.forEach((link) => link.addEventListener("click", closeDrawer));

  // Navbar shadow on scroll
  window.addEventListener("scroll", () => {
    const navbar = document.getElementById("navbar");
    if (window.scrollY > 10) {
      navbar?.classList.add("shadow-md");
    } else {
      navbar?.classList.remove("shadow-md");
    }
  });
</script>
