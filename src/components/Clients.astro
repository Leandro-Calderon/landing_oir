---
const clientLogos = [
  { alt: "Cliente 1", seed: "client1" },
  { alt: "Cliente 2", seed: "client2" },
  { alt: "Cliente 3", seed: "client3" },
  { alt: "Cliente 4", seed: "client4" },
  { alt: "Cliente 5", seed: "client5" },
  { alt: "Cliente 6", seed: "client6" },
];
---

<section
  class="py-16 bg-surface w-full overflow-hidden"
  id="clientes"
  aria-label="Clientes"
>
  <div class="w-full px-5 max-w-7xl mx-auto">
    <h2 class="text-xl font-bold text-center text-on-background mb-10">
      Empresas que confían en nosotros
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8 items-center opacity-70">
      {clientLogos.map((client) => (
        <div class="flex justify-center p-2 grayscale hover:grayscale-0 transition-all duration-300 reveal">
          <img
            alt={client.alt}
            class="h-10 w-auto object-contain"
            src={`https://picsum.photos/seed/${client.seed}/160/60`}
            loading="lazy"
            width="160"
            height="60"
          />
        </div>
      ))}
    </div>
  </div>
</section>
