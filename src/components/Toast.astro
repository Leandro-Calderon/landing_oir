  class="fixed top-20 left-1/2 -translate-x-1/2 bg-secondary text-white px-6 py-3 rounded-lg shadow-2xl opacity-0 pointer-events-none transition-all duration-300 z-[100] font-medium text-sm flex items-center gap-3 w-[90%] max-w-xs"
  role="status"
  aria-live="polite"
