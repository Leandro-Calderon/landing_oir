---
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-10 border-t border-outline bg-surface-alt overflow-hidden">
  <div class="w-full px-5 max-w-7xl mx-auto flex flex-col items-center gap-6 text-center">
    <!-- Brand -->
    <div class="flex flex-col items-center gap-2">
      <span class="font-bold text-primary text-lg">O.I.R. Seguridad</span>
      <p class="text-xs font-medium uppercase tracking-widest text-on-surface">
        Protección con trayectoria
      </p>
    </div>

    <!-- Copyright -->
    <p class="text-xs font-medium text-on-surface leading-relaxed">
      &copy; {currentYear} O.I.R. Seguridad. Todos los derechos reservados.<br />
      Desarrollado por <span class="text-primary font-bold">Lisandro Calegari</span>
    </p>

    <!-- Links -->
    <div class="flex gap-6">
      <a class="text-on-surface hover:text-primary transition-colors text-xs font-bold uppercase tracking-widest" href="#">
        Privacidad
      </a>
      <a class="text-on-surface hover:text-primary transition-colors text-xs font-bold uppercase tracking-widest" href="#">
        Términos
      </a>
    </div>
  </div>
</footer>
